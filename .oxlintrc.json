{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "vitest"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "vitest/expect-expect": [
      "error",
      { "assertFunctionNames": ["expect", "waitFor"] }
    ]
  },
  "env": {
    "builtin": true
  }
}
