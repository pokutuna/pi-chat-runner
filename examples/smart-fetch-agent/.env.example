# cp .env.example .env, then fill in the values (read by docker compose)

SLACK_APP_TOKEN=xapp-...
SLACK_BOT_TOKEN=xoxb-...
SLACK_BOT_USER_ID=U...

GOOGLE_CLOUD_PROJECT=my-gcp-project
GOOGLE_CLOUD_LOCATION=global
# The default ADC path works after `gcloud auth application-default login`
GOOGLE_APPLICATION_CREDENTIALS=${HOME}/.config/gcloud/application_default_credentials.json

# allowAddons already defaults to true in config/agent.yaml for this example;
# set to 0 to disable (e.g. to confirm pi-smart-fetch's load is rejected
# without --allow-addons)
PI_ALLOW_ADDONS=1
