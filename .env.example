# cp .env.example .env して値を埋める (`pnpm run dev` が --env-file-if-exists=.env で読む)

# Bot User OAuth Token (OAuth & Permissions で取得)
SLACK_BOT_TOKEN=xoxb-...

# App-Level Token, connections:write scope (Basic Information > App-Level Tokens)
SLACK_APP_TOKEN=xapp-...

# bot の User ID (auth.test の user_id)
SLACK_BOT_USER_ID=U...

# pi のモデル・プロバイダ指定 (任意。ChannelDoc.model 未指定時に使われる)
# PI_PROVIDER=google-vertex
# PI_MODEL=gemini-3.5-flash

# Vertex AI 利用時 (PI_PROVIDER=google-vertex) に pi 子プロセスへ透過する GCP 設定 (任意)
# GOOGLE_CLOUD_PROJECT=my-gcp-project
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ログレベル (任意。既定 info。pi の stderr など詳細を見たいときは debug)
# LOG_LEVEL=debug
