# cp .env.example .env して値を埋める (`pnpm run dev` が --env-file-if-exists=.env で読む)
#
# ここに並ぶ env の多くは examples/config/agent.yaml が ${env.X} / ${env.X:-default}
# で参照する source。agent.yaml 側の既定値を上書きしたいときだけ .env に値を置く
# (config.md §6: 優先順位は env > agent.yaml > コード既定)。

# Bot User OAuth Token (OAuth & Permissions で取得)
SLACK_BOT_TOKEN=xoxb-...

# bot の User ID (auth.test の user_id)
SLACK_BOT_USER_ID=U...

# 入口の選択 (任意。socket | events。既定 socket。design/architecture.md §1)
# socket: ローカル確認・お試し用途 (WebSocket)。events: Cloud Run 本番用途 (HTTP push)
# SLACK_MODE=socket

# --- SLACK_MODE=socket の場合に必要 ---
# App-Level Token, connections:write scope (Basic Information > App-Level Tokens)
SLACK_APP_TOKEN=xapp-...

# --- SLACK_MODE=events の場合に必要 ---
# Signing Secret (Basic Information > App Credentials)。/slack/events の署名検証に使う
# SLACK_SIGNING_SECRET=...

# events モードの listen ポート (任意。既定 8080)
# PORT=8080

# pi のプロバイダ指定 (任意)。pi のモデルは channels.yaml の model で指定する
# (default / channel。未指定なら pi 既定)。env にモデル設定は無い。
# PI_PROVIDER=google-vertex

# 1 ターンの上限 (ms)。超過で pi を kill する (任意。既定 600000 = 10 分)
# TURN_TIMEOUT_MS=600000

# 長時間ターンの進捗通知の間隔 (ms)。0 で無効化 (任意。既定 5000)
# PROGRESS_NOTICE_INTERVAL_MS=5000

# Vertex AI 利用時 (PI_PROVIDER=google-vertex) に pi 子プロセスへ透過する GCP 設定 (任意)
# GOOGLE_CLOUD_PROJECT=my-gcp-project
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ログレベル (任意。既定 info。pi の stderr など詳細を見たいときは debug)
# LOG_LEVEL=debug

# 永続化バックエンド (任意。memory | sqlite | firestore。既定 memory)
# firestore はエミュレータなら FIRESTORE_EMULATOR_HOST、本番なら GOOGLE_CLOUD_PROJECT を SDK が読む
# STORE_BACKEND=sqlite
# SQLITE_PATH=/tmp/pi-chat-runner/state.db

# workdir のセッション境界退避先 (任意。未設定なら退避なし = ローカル置きっぱなし)
# WORKDIR_ARCHIVE_DIR=/tmp/pi-chat-runner/archive

# Node Permission Model 経由での pi 起動 (任意。design/session-runtime.md §6、
# research/pi-tools-and-sandbox.md 「リーズナブルな sandbox レイヤ案」)。
# コード既定 ON (書かなければ隔離が効く)。ローカル開発の fake pi で無効化したいときは
# 0 をセットする (agent.yaml の agent.runtime.permissionMode より優先される)
# PI_PERMISSION_MODE=0

# UID/GID 分離 (任意。両方セット必須。片方だけは fail-loud。
# agent.yaml の agent.runtime.uid/gid より優先される)
# PI_AGENT_UID=1001
# PI_AGENT_GID=1001

# pi 子プロセスへ常に HOME として渡すディレクトリ (任意。既定 /home/agent。
# agent.yaml の agent.runtime.home より優先される)
# PI_AGENT_HOME=/home/agent

# pi 子プロセスへ渡す任意の env (agent.yaml の agent.env の ${env.GH_TOKEN} が拾う)。
# private リポジトリを pi から読む場合などに設定する
# GH_TOKEN=ghp_...
