{
  "name": "pi-chat-runner",
  "version": "0.1.1",
  "private": true,
  "files": [
    "dist",
    "extensions",
    "builtin-skills",
    "skills"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./store/firestore": {
      "types": "./dist/store/state/backends/firestore.d.mts",
      "default": "./dist/store/state/backends/firestore.mjs"
    },
    "./store/sqlite": {
      "types": "./dist/store/state/backends/sqlite.d.mts",
      "default": "./dist/store/state/backends/sqlite.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsx watch --env-file-if-exists=.env src/server.ts",
    "dev:socket": "tsx watch --env-file-if-exists=.env.socket src/server.ts",
    "dev:local": "tsx --env-file-if-exists=.env.local src/server.ts local",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint . && oxfmt --check .",
    "format": "oxfmt --write ."
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.10",
    "@google-cloud/firestore": "^8.6.0",
    "@google/genai": "^2.12.0",
    "@slack/socket-mode": "^3.0.0",
    "@slack/web-api": "^8.0.0",
    "better-sqlite3": "^12.11.1",
    "hono": "^4.12.30",
    "ink": "^7.1.1",
    "pino": "^10.3.1",
    "react": "^19.2.7",
    "string-width": "^8.2.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "ink-testing-library": "^4.0.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "pino-pretty": "^13.1.3",
    "tsdown": "^0.22.9",
    "tsx": "^4.23.1",
    "typebox": "^1.3.6",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=26"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "protobufjs"
    ]
  }
}
