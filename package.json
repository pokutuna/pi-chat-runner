{
  "name": "pi-chat-runner",
  "version": "0.1.1",
  "private": true,
  "files": [
    "dist",
    "extensions",
    "skills"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./store/firestore": {
      "types": "./dist/store/state/backends/firestore.d.mts",
      "default": "./dist/store/state/backends/firestore.mjs"
    },
    "./store/sqlite": {
      "types": "./dist/store/state/backends/sqlite.d.mts",
      "default": "./dist/store/state/backends/sqlite.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "prepare": "[ -n \"$SKIP_PREPARE\" ] || tsdown",
    "dev": "tsx watch --env-file-if-exists=.env src/server.ts",
    "dev:socket": "tsx watch --env-file-if-exists=.env.socket src/server.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint . && oxfmt --check .",
    "format": "oxfmt --write ."
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.9",
    "@google-cloud/firestore": "^8.6.0",
    "@google/genai": "^2.10.0",
    "@slack/socket-mode": "^2.0.7",
    "@slack/web-api": "^7.18.0",
    "better-sqlite3": "^12.11.1",
    "hono": "^4.12.27",
    "pino": "^10.3.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.0",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "pino-pretty": "^13.1.3",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.4",
    "typebox": "^1.3.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=26"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "protobufjs"
    ]
  }
}
