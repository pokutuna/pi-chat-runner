{
	"name": "pi-chat-runner",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=26"
	},
	"packageManager": "pnpm@10.30.3",
	"scripts": {
		"build": "tsdown",
		"dev": "tsx watch --env-file-if-exists=.env src/server.ts",
		"test": "vitest run",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"format": "biome format --write ."
	},
	"dependencies": {
		"@google-cloud/firestore": "^8.6.0",
		"@slack/socket-mode": "^2.0.7",
		"@slack/web-api": "^7.18.0",
		"hono": "^4.12.27",
		"yaml": "^2.9.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.2",
		"@earendil-works/pi-coding-agent": "^0.79.9",
		"@types/node": "^26.1.0",
		"tsdown": "^0.22.3",
		"tsx": "^4.22.4",
		"typebox": "^1.3.2",
		"typescript": "^6.0.3",
		"vitest": "^4.1.9"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"protobufjs"
		]
	}
}
